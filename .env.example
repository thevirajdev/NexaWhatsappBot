# Port for Express server
PORT=3000

# WhatsApp Session Name
SESSION_ID=nex-automate-session

# MongoDB Connection String
MONGODB_URI=mongodb://localhost:27017/whatsapp_bot

# AI Configuration (Gemini)
# Get your API key from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Email Configuration (Nodemailer - Gmail recommended)
# Use App Password if 2FA is enabled
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
REPORT_RECEIVER=your_report_receiver_email@gmail.com

# Bot Configuration
ADMIN_PHONE=your_admin_phone_number@c.us
MANUAL_OVERRIDE=false
RESPONSE_DELAY_MIN=2000
RESPONSE_DELAY_MAX=5000
