<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NexAutomate | Voice Campaign</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        .form-group { margin-bottom: 20px; }
        .form-group label { display: block; margin-bottom: 8px; font-weight: 500; }
        .form-group input, .form-group select, .form-group textarea { width: 100%; padding: 10px; border-radius: 6px; border: 1px solid #334155; background: #1e293b; color: white; margin-bottom: 15px;}
        .btn-submit { background: #3b82f6; color: white; border: none; padding: 10px 20px; border-radius: 6px; cursor: pointer; font-weight: 600; }
        .btn-submit:hover { background: #2563eb; }
        .result-box { padding: 15px; background: #0f172a; border-radius: 6px; border: 1px solid #334155; margin-top: 15px; color: #10b981; display: none;}
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="logo">NexAutomate</div>
        <nav>
            <a href="/" class="nav-item">Dashboard</a>
            <a href="/agent" class="nav-item">AI Admin Assistant</a>
            <a href="/settings" class="nav-item">Settings / Voice AI</a>
            <a href="/campaign" class="nav-item active">Voice Campaigns</a>
        </nav>
    </div>

    <main class="content">
        <header>
            <h1>Voice Outbound Campaign</h1>
        </header>

        <section class="card">
            <h3>Start a Voice Campaign</h3>
            <p>Enter a comma-separated list of phone numbers (with country code) and select the Voice AI mode. The bot will trigger your configured Voice Provider to make the calls.</p>
            <br>

            <div class="form-group">
                <label>Phone Numbers (e.g., +919876543210, +1234567890)</label>
                <textarea id="numbers" rows="4" placeholder="Enter numbers here..."></textarea>
            </div>

            <div class="form-group">
                <label>Voice Mode / Persona</label>
                <select id="mode">
                    <option value="sales">Sales (Premium NexAutomate Pitch)</option>
                    <option value="friend">Friend / Personal (Casual Hinglish)</option>
                </select>
            </div>

            <button onclick="launchCampaign()" class="btn-submit" id="callBtn">Launch Voice AI Calls</button>

            <div id="resultBox" class="result-box"></div>
        </section>
    </main>

    <script>
        async function launchCampaign() {
            const btn = document.getElementById('callBtn');
            const resBox = document.getElementById('resultBox');
            const numbers = document.getElementById('numbers').value;
            const mode = document.getElementById('mode').value;
            
            if(!numbers.trim()) {
                alert("Please enter numbers");
                return;
            }

            btn.disabled = true;
            btn.innerText = 'Calling...';
            resBox.style.display = 'none';

            try {
                const response = await fetch('/campaign', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ numbers, mode })
                });

                const data = await response.json();
                resBox.style.display = 'block';
                
                if (data.success) {
                    resBox.innerHTML = `<strong>Campaign Launched!</strong><br><br> ${data.results.map(r => `&#8226; ${r.number}: ${r.status}`).join('<br>')}`;
                } else {
                    resBox.style.color = '#ef4444';
                    resBox.innerText = 'Error: ' + data.error;
                }
            } catch (err) {
                resBox.style.display = 'block';
                resBox.style.color = '#ef4444';
                resBox.innerText = 'Network error occurred.';
            }

            btn.disabled = false;
            btn.innerText = 'Launch Voice AI Calls';
        }
    </script>
</body>
</html>
